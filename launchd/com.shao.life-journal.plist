<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.shao.life-journal</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/shao/Projects/telegram-inbox-bot/launchd/life-journal-commit.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>23</integer>
        <key>Minute</key>
        <integer>55</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/shao/Projects/telegram-inbox-bot/logs/life-journal.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/shao/Projects/telegram-inbox-bot/logs/life-journal.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>LIFE_DIR</key>
        <string>/Users/shao/Projects/life</string>
    </dict>
</dict>
</plist>
