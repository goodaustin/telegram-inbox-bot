TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
OPENAI_API_KEY=sk-proj-...
# 分類器 provider：openai 或 gemini
CLASSIFIER_PROVIDER=openai
# provider=gemini 時填（Google AI Studio 取得）
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
NOTION_TOKEN=ntn_...
NOTION_DB_RESTAURANT=
NOTION_DB_PLACE=
NOTION_DB_TODO=
NOTION_DB_ARTICLE=
NOTION_DB_QUOTE=
NOTION_DB_APPAREL=
NOTION_DB_SKINCARE=
NOTION_DB_PHOTO=
NOTION_DB_FUNNY=
NOTION_DB_INBOX=
CLASSIFIER_MODEL=gpt-4.1-mini
# gemini 時改為 gemini-2.5-flash
CONFIDENCE_THRESHOLD=0.5
TIMEZONE=Asia/Taipei
# 週日摘要提醒開關：true=啟用（預設）；朋友端不要提醒就設 false
DIGEST_ENABLED=true
DIGEST_HOUR=7
DIGEST_MINUTE=30
# 私人 life repo 絕對路徑（日記/名言/提醒）。留空則 /j /s /g /b 與提醒全部停用。
# 例：LIFE_DIR=/Users/shao/Projects/life
LIFE_DIR=
